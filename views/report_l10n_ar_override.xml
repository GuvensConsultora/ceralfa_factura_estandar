<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Mejoras visuales al documento de factura estándar l10n_ar.
        Por qué: El template l10n_ar.report_invoice_document define el CONTENIDO
        de la factura (datos cliente, tabla de líneas, totales).
        El LAYOUT (header/footer) lo maneja external_layout_arca.
        Estas mejoras aplican al contenido sin importar qué layout esté activo.
        Patrón: Solo modifica atributos de estilo (no estructura) → compatible con herencias.
    -->
    <template id="l10n_ar_visual_improvements" inherit_id="l10n_ar.report_invoice_document">

        <!-- 1. Mejorar spacing y tipografía del bloque informaciones -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class">row mt-3 mb-3</attribute>
            <attribute name="style">font-size: 11px;</attribute>
        </xpath>

        <!-- 2. Borde y padding al bloque izquierdo (datos del cliente) -->
        <xpath expr="//div[@id='informations']/div[@class='col-6'][1]" position="attributes">
            <attribute name="style">border: 1px solid #dee2e6; border-radius: 4px; padding: 10px;</attribute>
        </xpath>

        <!-- 3. Borde y padding al bloque derecho (datos de la factura) -->
        <xpath expr="//div[@id='informations']/div[@class='col-6'][2]" position="attributes">
            <attribute name="style">border: 1px solid #dee2e6; border-radius: 4px; padding: 10px;</attribute>
        </xpath>

        <!-- 4. Fondo gris claro en header de la tabla de líneas -->
        <xpath expr="//table[@name='invoice_line_table']/thead/tr" position="attributes">
            <attribute name="style">background-color: #f8f9fa;</attribute>
        </xpath>

        <!-- 5. Separador visual marcado antes de la sección de totales -->
        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="style">border-top: 2px solid #000; padding-top: 10px;</attribute>
        </xpath>

    </template>

    <!--
        Mover "Impuestos AR" a la izquierda, al lado del cuadro de subtotal/impuestos/total.
        Por qué: Ambos cuadros quedan a la misma altura en la misma fila.
        El de Impuestos AR (company currency) a la izquierda y el de totales a la derecha.
        Patrón: Convertir right-elements en flex container, insertar Impuestos AR antes de div#total.
    -->
    <template id="l10n_ar_impuestos_ar_left" inherit_id="l10n_ar.report_invoice_document">

        <!--
            1. Ampliar right-elements a ancho completo y usar flexbox.
            Por qué: right-elements originalmente es col-5 float-end.
            Lo cambiamos a col-12 con d-flex para que ambos cuadros
            (Impuestos AR + Totales) queden lado a lado alineados a la derecha.
        -->
        <xpath expr="//div[@id='right-elements']" position="attributes">
            <attribute name="class">col-12 float-end d-flex justify-content-end align-items-start gap-4</attribute>
        </xpath>

        <!--
            2. Insertar cuadro Impuestos AR ANTES de div#total (queda a la izquierda).
            Por qué: position="before" sobre div#total lo coloca como hermano izquierdo
            dentro del flex container, así ambos cuadros quedan en la misma fila.
        -->
        <xpath expr="//div[@id='total']" position="before">
            <t t-if="o.tax_totals and o.tax_totals.get('display_in_company_currency')">
                <t t-set="tax_totals" t-value="o.tax_totals"/>
                <!-- Safety net: asegurar keys Enterprise en dict Community -->
                <t t-foreach="tax_totals.get('subtotals', [])" t-as="_sub">
                    <t t-set="_" t-value="_sub.setdefault('amount_company_currency', _sub.get('base_amount', 0))"/>
                    <t t-foreach="_sub.get('tax_groups', [])" t-as="_tg">
                        <t t-set="_" t-value="_tg.setdefault('tax_amount_company_currency', _tg.get('tax_amount', 0))"/>
                        <t t-set="_" t-value="_tg.setdefault('display_base_amount_company_currency', _tg.get('display_base_amount', False))"/>
                    </t>
                </t>
                <t t-set="_" t-value="tax_totals.setdefault('total_amount_company_currency', tax_totals.get('total_amount', 0))"/>
                <div class="flex-shrink-0" style="min-width: 45%;">
                    <t t-call="account.document_tax_totals_company_currency_template"/>
                </div>
            </t>
        </xpath>

        <!--
            3. Ocultar Impuestos AR original (el que viene dentro de div#total).
            Por qué: Ya lo mostramos como cuadro separado a la izquierda,
            no queremos duplicarlo dentro del cuadro de totales.
        -->
        <xpath expr="//div[@id='total']//t[@t-call='account.document_tax_totals_company_currency_template']/.."
               position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

    </template>

</odoo>
